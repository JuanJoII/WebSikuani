---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/Button.astro';
import SectionHeader from '../components/SectionHeader.astro';

const content = {
	light: {
		hero: {
			title: "RESERVAS.",
			description: "Inicie su viaje hacia el descanso consciente."
		},
		sidebar: {
			title: "RESUMEN",
			room: "ECO-SUITE RAINFOREST",
			price: "$1,800.00",
			details: "6 Noches / 2 Adultos",
			taxes: "$342.00",
			sustainability: "$45.00",
			total: "$2,187.00",
			btn: "CONFIRMAR RESERVA",
			policy: "Cancelación gratuita hasta 48 horas antes del Check-In."
		}
	},
	dark: {
		hero: {
			title: "RESERVAS.",
			description: "Asegure su lugar en el santuario donde el tiempo se desvanece entre las sombras del bosque."
		},
		sidebar: {
			title: "Tu Estadía",
			room: "ECO-SUITE RAINFOREST",
			price: "$1,800.00",
			details: "6 Noches x $300",
			taxes: "$342.00",
			sustainability: "$45.00",
			total: "$2,187.00",
			btn: "Confirmar Reserva",
			policy: "Cancelación gratuita hasta 48 horas antes del Check-In."
		},
		rituals: [
			{ title: "Ritual del Bosque", img: "https://images.unsplash.com/photo-1544161515-4ad6ce175068?auto=format&fit=crop&q=80&w=400" },
			{ title: "Amanecer Silente", img: "https://images.unsplash.com/photo-1506126613408-eca07ce68773?auto=format&fit=crop&q=80&w=400" },
			{ title: "Gastronomía de Raíz", img: "https://images.unsplash.com/photo-1504674900247-0877df9cc836?auto=format&fit=crop&q=80&w=400" }
		]
	}
};
---

<Layout title="Reservas - Sikuani Rend">

	<main class="transition-colors duration-700 bg-sikuani-bg min-h-screen">
		<section class="py-24">
			<div class="container mx-auto px-4">
				<div class="max-w-4xl mb-16">
					<h1 class="text-7xl md:text-9xl font-serif text-sikuani-primary mb-6 tracking-tighter">RESERVAS.</h1>
					<p class="text-xl md:text-2xl text-sikuani-on-surface/80 font-sans max-w-xl">
						<span class="block dark:hidden">{content.light.hero.description}</span>
						<span class="hidden dark:block">{content.dark.hero.description}</span>
					</p>
				</div>

				<div class="flex flex-col lg:flex-row gap-12 items-start">
					<!-- Main Booking Interface -->
					<div class="w-full lg:w-2/3 bg-sikuani-surface rounded-sikuani-card p-8 md:p-12 border border-sikuani-primary/5 shadow-sm">
						<!-- Custom Form / Calendar Mockup -->
						<div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
							<div class="space-y-2">
								<label class="text-sm font-bold uppercase tracking-widest text-sikuani-primary">Llegada</label>
								<div class="w-full p-4 border-b-2 border-sikuani-primary/20 bg-sikuani-bg/30 font-sans">14 Oct. 2024</div>
							</div>
							<div class="space-y-2">
								<label class="text-sm font-bold uppercase tracking-widest text-sikuani-primary">Salida</label>
								<div class="w-full p-4 border-b-2 border-sikuani-primary/20 bg-sikuani-bg/30 font-sans">18 Oct. 2024</div>
							</div>
						</div>

						<!-- Calendar Mock -->
						<div class="mb-12">
							<div class="flex justify-between items-center mb-8">
								<h3 class="text-2xl font-serif text-sikuani-primary">Octubre 2024</h3>
								<div class="flex gap-4">
									<button class="p-2 border border-sikuani-primary/10 rounded-full">&larr;</button>
									<button class="p-2 border border-sikuani-primary/10 rounded-full">&rarr;</button>
								</div>
							</div>
							<div class="grid grid-cols-7 gap-2 text-center text-sm font-sans">
								{['D', 'L', 'M', 'M', 'J', 'V', 'S'].map(d => <div class="font-bold opacity-40 py-2">{d}</div>)}
								<div class="py-4"></div>
								<div class="py-4"></div>
								{Array.from({ length: 31 }).map((_, i) => {
									const day = i + 1;
									const isSelected = (day >= 14 && 18 >= day);
									return (
										<div 
											class:list={[
												"py-4 rounded-sikuani-org transition-colors cursor-pointer",
												isSelected 
													? "bg-sikuani-primary text-white dark:text-black font-bold" 
													: "hover:bg-sikuani-primary/5"
											]}
										>
											{day}
										</div>
									);
								})}
							</div>
						</div>
					</div>

					<!-- Sidebar Summary -->
					<aside class="w-full lg:w-1/3 space-y-8 sticky top-32">
						<div class="bg-sikuani-surface rounded-sikuani-card p-8 border-2 border-sikuani-primary/10 shadow-xl">
							<h2 class="text-2xl font-serif text-sikuani-primary mb-8 border-b border-sikuani-primary/10 pb-4">
								<span class="block dark:hidden">{content.light.sidebar.title}</span>
								<span class="hidden dark:block">{content.dark.sidebar.title}</span>
							</h2>

							<!-- Suite Image (Dark Mode Style) -->
							<div class="hidden dark:block mb-8 rounded-sikuani-org overflow-hidden aspect-video">
								<img src="https://images.unsplash.com/photo-1590490360182-c33d57733427?auto=format&fit=crop&q=80&w=600" alt="Premium Suite" class="w-full h-full object-cover" />
							</div>

							<div class="space-y-6 font-sans">
								<div class="flex justify-between items-end">
									<div>
										<h4 class="font-bold text-lg">{content.light.sidebar.room}</h4>
										<p class="text-sm opacity-60">
											<span class="block dark:hidden">{content.light.sidebar.details}</span>
											<span class="hidden dark:block">{content.dark.sidebar.details}</span>
										</p>
									</div>
									<span class="text-xl font-serif">{content.light.sidebar.price}</span>
								</div>

								<div class="pt-6 border-t border-sikuani-primary/5 space-y-4 text-sm opacity-80">
									<div class="flex justify-between">
										<span>Tasa de Sostenibilidad</span>
										<span>
											<span class="block dark:hidden">{content.light.sidebar.sustainability}</span>
											<span class="hidden dark:block">{content.dark.sidebar.sustainability}</span>
										</span>
									</div>
									<div class="flex justify-between">
										<span>Cargos e Impuestos</span>
										<span>
											<span class="block dark:hidden">{content.light.sidebar.taxes}</span>
											<span class="hidden dark:block">{content.dark.sidebar.taxes}</span>
										</span>
									</div>
								</div>

								<div class="pt-6 border-t border-sikuani-primary/20 flex justify-between items-center text-2xl font-serif text-sikuani-primary">
									<span>Total</span>
									<span>
										<span class="block dark:hidden">{content.light.sidebar.total}</span>
										<span class="hidden dark:block">{content.dark.sidebar.total}</span>
									</span>
								</div>

								<Button variant="primary" class="w-full py-5 text-lg mt-8 uppercase tracking-widest">
									<span class="block dark:hidden">{content.light.sidebar.btn}</span>
									<span class="hidden dark:block">{content.dark.sidebar.btn}</span>
								</Button>

								<p class="text-xs text-center opacity-50 mt-6 italic">
									<span class="block dark:hidden">{content.light.sidebar.policy}</span>
									<span class="hidden dark:block">{content.dark.sidebar.policy}</span>
								</p>
							</div>
						</div>
					</aside>
				</div>
			</div>
		</section>

		<!-- Dark Mode Exclusive: Rituals/Experiences -->
		<section class="py-32 bg-sikuani-surface hidden dark:block border-t border-sikuani-primary/10">
			<div class="container mx-auto px-4">
				<SectionHeader title="Experiencia Inmersiva" subtitle="Complementos" centered={true} />
				<div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-16">
					{content.dark.rituals.map(ritual => (
						<div class="group cursor-pointer">
							<div class="aspect-4/5 rounded-sikuani-card overflow-hidden mb-6 relative">
								<img src={ritual.img} alt={ritual.title} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
								<div class="absolute inset-0 bg-linear-to-t from-black/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-8">
									<span class="text-white font-serif text-2xl">{ritual.title}</span>
								</div>
							</div>
							<h3 class="font-sans font-bold uppercase tracking-widest text-sm text-center group-hover:text-sikuani-primary transition-colors">{ritual.title}</h3>
						</div>
					))}
				</div>
			</div>
		</section>
	</main>

</Layout>
