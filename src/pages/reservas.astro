---
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';
import SectionHeader from '../components/SectionHeader.astro';

const base = import.meta.env.BASE_URL;

const selectedRoom = {
	title: "ECO-SUITE RAINFOREST",
	details: "6 Noches / 2 Adultos",
	pricePerNight: "$300.00",
	subtotal: "$1,800.00",
	sustainabilityTax: "$45.00",
	taxes: "$342.00",
	total: "$2,187.00",
	image: "https://images.unsplash.com/photo-1590490360182-c33d57733427?auto=format&fit=crop&q=80&w=600"
};

const complementaryExperiences = [
	{ title: "Ritual del Bosque (Yoga)", img: "https://images.unsplash.com/photo-1506126613408-eca07ce68773?auto=format&fit=crop&q=80&w=400", price: "$40" },
	{ title: "Amanecer Silente (Trekking)", img: "https://images.unsplash.com/photo-1487525219605-eadb39ae229c?auto=format&fit=crop&q=80&w=400", price: "$25" },
	{ title: "Gastronomía Ancestral (Cena)", img: "https://images.unsplash.com/photo-1544644181-1484b3fdfc62?auto=format&fit=crop&q=80&w=400", price: "$60" }
];
---

<Layout title="Reservas - Sikuani Ecohotel">
	<main class="bg-canvas text-body min-h-screen overflow-x-hidden">
		<section class="py-24 max-w-[1200px] mx-auto px-6">
			<div class="max-w-4xl mb-16 select-none booking-header">
				<h1 class="text-6xl md:text-8xl font-serif text-primary tracking-tighter">Reservas.</h1>
				<p class="text-lg md:text-xl text-muted font-sans mt-4 max-w-xl">
					Inicia tu viaje hacia el descanso consciente. Configura las fechas de tu estadía y complementa tu inmersión.
				</p>
			</div>

			<!-- Layout estructural: 65% izquierda (Calendario/Opciones), 35% derecha (Sidebar Sticky) -->
			<div class="flex flex-col lg:flex-row gap-12 items-start relative">
				
				<!-- Columna Izquierda: Formulario e Interfaz de Fechas (65%) -->
				<div class="w-full lg:w-[65%] space-y-12 booking-form-container">
					<div class="bg-canvas dark:bg-dark-surface border border-hairline dark:border-dark-hairline rounded-md p-8 shadow-hover space-y-8 select-none">
						<h3 class="text-xl font-serif font-bold text-ink border-b border-hairline dark:border-dark-hairline pb-4">
							1. Selección de Estadía
						</h3>

						<!-- Inputs de Llegada y Salida -->
						<div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
							<div class="space-y-2">
								<label class="text-[10px] font-bold uppercase tracking-widest text-primary">Llegada</label>
								<div class="w-full p-4 border border-hairline dark:border-dark-hairline bg-surface-soft dark:bg-dark-surface-soft text-ink dark:text-dark-ink font-sans rounded-sm text-sm font-semibold">
									14 Oct. 2024 (Check-In)
								</div>
							</div>
							<div class="space-y-2">
								<label class="text-[10px] font-bold uppercase tracking-widest text-primary">Salida</label>
								<div class="w-full p-4 border border-hairline dark:border-dark-hairline bg-surface-soft dark:bg-dark-surface-soft text-ink dark:text-dark-ink font-sans rounded-sm text-sm font-semibold">
									20 Oct. 2024 (Check-Out)
								</div>
							</div>
						</div>

						<!-- Calendario Mockup Interactivo -->
						<div class="pt-4">
							<div class="flex justify-between items-center mb-6">
								<h4 class="text-base font-serif font-bold text-ink">Octubre 2024</h4>
								<div class="flex gap-2">
									<button class="h-8 w-8 border border-hairline dark:border-dark-hairline rounded-full flex items-center justify-center text-ink hover:bg-surface-soft dark:hover:bg-dark-surface-soft transition-colors">&larr;</button>
									<button class="h-8 w-8 border border-hairline dark:border-dark-hairline rounded-full flex items-center justify-center text-ink hover:bg-surface-soft dark:hover:bg-dark-surface-soft transition-colors">&rarr;</button>
								</div>
							</div>
							
							<div class="grid grid-cols-7 gap-1.5 text-center text-xs font-sans">
								<!-- Días de la semana -->
								{['D', 'L', 'M', 'M', 'J', 'V', 'S'].map(d => (
									<div class="font-bold text-muted py-2 select-none">{d}</div>
								))}
								
								<!-- Espacios vacíos para iniciar el mes -->
								<div class="py-3"></div>
								<div class="py-3"></div>
								
								<!-- Días del mes con rango seleccionado (14 al 20) -->
								{Array.from({ length: 31 }).map((_, i) => {
									const day = i + 1;
									const isSelected = day >= 14 && 20 >= day;
									const isEdge = (day === 14 || day === 20);
									
									return (
										<div 
											class:list={[
												"py-3.5 rounded-sm transition-all duration-300 cursor-pointer font-semibold",
												isSelected 
													? isEdge 
														? "bg-primary text-white scale-105 font-bold shadow-md"
														: "bg-accent/25 dark:bg-dark-accent/20 text-primary dark:text-dark-primary"
													: "text-ink hover:bg-surface-soft dark:hover:bg-dark-surface-soft"
											]}
										>
											{day}
										</div>
									);
								})}
							</div>
						</div>
					</div>

					<!-- Sección de Complementos / Inmersión -->
					<div class="bg-canvas dark:bg-dark-surface border border-hairline dark:border-dark-hairline rounded-md p-8 shadow-hover space-y-8 select-none addon-section">
						<h3 class="text-xl font-serif font-bold text-ink border-b border-hairline dark:border-dark-hairline pb-4">
							2. Complementa tu Inmersión
						</h3>
						
						<div class="grid grid-cols-1 sm:grid-cols-3 gap-6 addon-grid">
							{complementaryExperiences.map(exp => (
								<div class="addon-item border border-hairline dark:border-dark-hairline rounded-md overflow-hidden bg-canvas dark:bg-dark-surface-soft hover:border-primary/30 transition-all duration-300 cursor-pointer shadow-hover">
									<div class="aspect-video overflow-hidden">
										<img src={exp.img} alt={exp.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
									</div>
									<div class="p-4 space-y-3">
										<h4 class="font-sans font-bold text-ink text-xs line-clamp-1 group-hover:text-primary transition-colors">{exp.title}</h4>
										<div class="flex justify-between items-center pt-2 border-t border-hairline/60 dark:border-dark-hairline/60">
											<span class="text-xs text-primary font-bold">{exp.price}</span>
											<span class="text-[9px] uppercase font-bold text-muted tracking-wider">Agregar +</span>
										</div>
									</div>
								</div>
							))}
						</div>
					</div>
				</div>

				<!-- Columna Derecha: Sidebar Sticky de Resumen (35%) -->
				<!-- En móvil (< 744px) se adapta al panel inferior flotante mediante clases CSS adaptativas -->
				<aside class="w-full lg:w-[35%] lg:sticky lg:top-28 z-40 booking-sidebar">
					<div class="bg-canvas dark:bg-dark-surface rounded-md p-6 md:p-8 border border-hairline dark:border-dark-hairline shadow-hover space-y-6">
						<h3 class="text-lg font-serif font-bold text-ink border-b border-hairline dark:border-dark-hairline pb-3 select-none">
							Resumen de Reserva
						</h3>

						<!-- Foto de Cabaña Seleccionada -->
						<div class="aspect-video rounded-md overflow-hidden bg-surface-soft select-none border border-hairline/60 dark:border-dark-hairline/60">
							<img src={selectedRoom.image} alt={selectedRoom.title} class="w-full h-full object-cover" />
						</div>

						<div class="space-y-4 font-sans select-none">
							<!-- Nombre e Info de cabaña -->
							<div class="flex justify-between items-start">
								<div>
									<h4 class="font-bold text-sm text-ink">{selectedRoom.title}</h4>
									<p class="text-[11px] text-muted font-medium mt-1">{selectedRoom.details}</p>
								</div>
								<span class="text-base font-serif font-bold text-primary">{selectedRoom.pricePerNight}</span>
							</div>

							<!-- Tasas e Impuestos -->
							<div class="pt-4 border-t border-hairline/60 dark:border-dark-hairline/60 space-y-3 text-xs text-muted font-medium">
								<div class="flex justify-between">
									<span>Tasa de Sostenibilidad Regenerativa</span>
									<span class="text-ink">{selectedRoom.sustainabilityTax}</span>
								</div>
								<div class="flex justify-between">
									<span>Impuestos de Preservación e IVA</span>
									<span class="text-ink">{selectedRoom.taxes}</span>
								</div>
							</div>

							<!-- Total General -->
							<div class="pt-4 border-t border-hairline dark:border-dark-hairline flex justify-between items-center text-xl font-serif font-bold text-primary">
								<span>Total</span>
								<span>{selectedRoom.total}</span>
							</div>

							<!-- Botón de Conversión de reserva instantánea en Amarillo Vibrante -->
							<Button variant="conversion" class="w-full py-6 text-xs mt-4 uppercase tracking-widest font-bold shadow-lg">
								Confirmar Reserva
							</Button>

							<p class="text-[10px] text-center text-muted font-medium mt-4 italic leading-relaxed">
								Cancelación gratuita hasta 48 horas antes del Check-In.
							</p>
						</div>
					</div>
				</aside>

			</div>
		</section>

		<!-- Adaptación de barra inferior flotante responsiva en móvil (< 744px) -->
		<!-- Esto cumple con la directiva: "Sticky right-rail booking modules shift into a persistent bottom execution panel" -->
		<div class="lg:hidden fixed bottom-0 left-0 w-full bg-canvas border-t border-hairline p-4 z-50 flex items-center justify-between shadow-2xl transition-colors duration-500 select-none mobile-booking-bar">
			<div>
				<span class="block text-[9px] uppercase font-bold text-muted tracking-wider">Total Estancia</span>
				<span class="text-lg font-serif font-bold text-primary">{selectedRoom.total}</span>
			</div>
			<Button variant="conversion" class="h-10 px-6 text-xs uppercase tracking-widest font-bold">
				Reservar
			</Button>
		</div>
	</main>
</Layout>

<script>
	import { gsap } from 'gsap';
	import { ScrollTrigger } from 'gsap/ScrollTrigger';
	
	gsap.registerPlugin(ScrollTrigger);

	// Animaciones de carga
	gsap.from(".booking-header", { opacity: 0, y: -20, duration: 0.8, ease: "power2.out" });
	gsap.from(".booking-form-container", { opacity: 0, x: -40, duration: 1, delay: 0.2, ease: "power2.out" });
	gsap.from(".booking-sidebar", { opacity: 0, x: 40, duration: 1, delay: 0.2, ease: "power2.out" });

	// Animaciones de los complementos al hacer scroll (Stagger)
	gsap.from(".addon-item", {
		scrollTrigger: {
			trigger: ".addon-section",
			start: "top 85%",
		},
		opacity: 0,
		y: 25,
		duration: 0.7,
		stagger: 0.15,
		ease: "power2.out"
	});

	// Animación de entrada de la barra flotante móvil si aparece en pantalla
	gsap.from(".mobile-booking-bar", {
		y: 60,
		opacity: 0,
		duration: 0.8,
		delay: 1,
		ease: "power3.out"
	});
</script>
