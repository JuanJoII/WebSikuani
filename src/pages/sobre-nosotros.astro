---
import Layout from '../layouts/Layout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import PageHero from '../components/PageHero.astro';

const values = [
	{ 
		title: "Sustentabilidad Activa", 
		desc: "Compromiso absoluto con la huella cero. Desde la gestión circular del agua hasta el uso de materiales de origen local certificado." 
	},
	{ 
		title: "Silencio Consciente", 
		desc: "Proporcionamos un espacio diseñado para la desconexión total. El silencio no es la ausencia de sonido, es la presencia de paz." 
	},
	{ 
		title: "Integración Biológica", 
		desc: "Nuestra arquitectura biomimética se adapta y respeta la flora y fauna locales, funcionando como una extensión viva de la selva." 
	}
];

const team = [
	{ name: "Sofía Montes", role: "Directora de Sostenibilidad", img: "https://i.pravatar.cc/300?img=32" },
	{ name: "Mateo Silva", role: "Arquitecto Biomimético", img: "https://i.pravatar.cc/300?img=33" },
	{ name: "Yara Jacanamijoy", role: "Guía Espiritual & Botánica", img: "https://i.pravatar.cc/300?img=35" },
	{ name: "Carlos Rúa", role: "Chef de Gastronomía Ancestral", img: "https://i.pravatar.cc/300?img=12" }
];
---

<Layout title="Sobre Nosotros - Sikuani Ecohotel">
	<main class="bg-canvas text-body overflow-x-hidden">
		<!-- Hero Section Estandarizado -->
		<PageHero 
			title="Un refugio nacido de la tierra y el respeto." 
			description="Sikuani surgió como un sueño de integración absoluta con el entorno. Ubicado en el corazón del bosque húmedo, nuestro hotel no fue construido sobre la naturaleza, sino dentro de ella, respetando los senderos ancestrales del viento y el curso de las aguas subterráneas."
		/>

		<!-- Misión y Visión Section -->
		<section class="py-24 border-b border-hairline bg-surface-soft/20 transition-colors duration-500 mission-section">
			<div class="max-w-[1200px] mx-auto px-6">
				<div class="flex flex-col lg:flex-row items-center gap-16">
					<!-- Misión -->
					<div class="w-full lg:w-1/2 space-y-8 mission-content">
						<SectionHeader 
							title="Nuestra Misión" 
							subtitle="Nuestra Razón de Ser"
						/>
						<p class="text-2xl md:text-3xl font-serif text-ink leading-snug italic font-normal">
							"Ofrecer una experiencia de lujo regenerativo que reconecte al ser humano con sus orígenes biológicos, protegiendo activamente la biodiversidad y fomentando el bienestar holístico de nuestros huéspedes y comunidad local."
						</p>
					</div>
					
					<!-- Imagen de apoyo (16:9) -->
					<div class="w-full lg:w-1/2 mission-img">
						<div class="aspect-video rounded-md overflow-hidden bg-surface-soft border border-hairline shadow-hover relative group select-none">
							<img 
								src="https://eco-monte-tierra-habitaciones-y-glamping.hotelesdelquindio.com/data/Images/OriginalPhoto/11744/1174460/1174460109/image-filandia-ecohotel-monte-tierra-habitaciones-y-glamping-37.JPEG" 
								alt="Cabaña Glamping Sikuani en el bosque" 
								class="w-full h-full object-cover group-hover:scale-105 transition-all duration-700" 
							/>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Valores Grid -->
		<section class="py-24 max-w-[1200px] mx-auto px-6 border-b border-hairline">
			<SectionHeader title="Nuestros Valores Fundacionales" subtitle="Pilares Orgánicos" centered={true} />
			
			<div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-16 values-grid">
				{values.map((v, i) => (
					<div class="value-item h-full">
						<div class="p-10 rounded-md bg-canvas border border-hairline hover:border-primary/20 transition-all duration-500 group shadow-hover flex flex-col justify-between h-full">
							<div>
								<!-- Número estilizado -->
								<div class="h-12 w-12 rounded-sm bg-accent text-ink flex items-center justify-center font-serif font-bold text-lg mb-8 group-hover:scale-105 transition-transform duration-300">
									0{i+1}
								</div>
								<h3 class="text-xl font-serif font-bold mb-4 text-ink">{v.title}</h3>
							</div>
							<p class="text-body font-sans text-sm leading-relaxed mt-4">{v.desc}</p>
						</div>
					</div>
				))}
			</div>
		</section>

		<!-- Equipo Sikuani -->
		<section class="py-24 bg-canvas transition-colors duration-500">
			<div class="max-w-[1200px] mx-auto px-6 text-center">
				<SectionHeader title="Guardianes del Refugio" subtitle="Talento Humano" centered={true} />
				
				<p class="text-base text-body max-w-3xl mx-auto mb-16 font-sans leading-relaxed">
					Detrás de cada detalle en Sikuani hay un equipo apasionado que comparte una visión de Sostenibilidad y amor por la tierra. Expertos en hospitalidad regenerativa, botánica, gastronomía local y terapias de bienestar dedicados a hacer de tu estadía una inmersión inolvidable.
				</p>
				
				<div class="grid grid-cols-2 md:grid-cols-4 gap-8 team-grid">
					{team.map(member => (
						<div class="team-item flex flex-col items-center group select-none">
							<!-- Retrato redondo -->
							<div class="aspect-square w-36 h-36 rounded-full overflow-hidden border-2 border-primary/20 bg-surface-soft group-hover:border-primary transition-colors duration-300 group-hover:scale-105 shadow-hover">
								<img 
									src={member.img} 
									alt={member.name} 
									class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-500"
								/>
							</div>
							<h4 class="font-sans font-bold text-ink mt-6 text-sm">{member.name}</h4>
							<p class="text-[10px] text-muted uppercase font-bold tracking-widest mt-1">{member.role}</p>
						</div>
					))}
				</div>
			</div>
		</section>
	</main>
</Layout>

<script>
	import { gsap } from 'gsap';
	import { ScrollTrigger } from 'gsap/ScrollTrigger';
	
	gsap.registerPlugin(ScrollTrigger);

	// Animaciones Hero
	gsap.from(".hero-tag", { opacity: 0, y: -20, duration: 0.8, ease: "power2.out" });
	gsap.from(".hero-title", { opacity: 0, y: 30, duration: 1.2, delay: 0.2, ease: "power3.out" });
	gsap.from(".hero-desc", { opacity: 0, y: 20, duration: 1, delay: 0.4, ease: "power2.out" });

	// Animaciones de scroll (ScrollTrigger)
	
	// Misión
	gsap.from(".mission-content", {
		scrollTrigger: {
			trigger: ".mission-section",
			start: "top 80%",
		},
		opacity: 0,
		x: -40,
		duration: 1,
		ease: "power2.out"
	});

	gsap.from(".mission-img", {
		scrollTrigger: {
			trigger: ".mission-section",
			start: "top 80%",
		},
		opacity: 0,
		x: 40,
		duration: 1,
		ease: "power2.out"
	});

	// Valores Fundacionales (Stagger)
	gsap.from(".value-item", {
		scrollTrigger: {
			trigger: ".values-grid",
			start: "top 85%",
		},
		opacity: 0,
		y: 40,
		duration: 0.8,
		stagger: 0.15,
		ease: "power2.out"
	});

	// Equipo (Stagger)
	gsap.from(".team-item", {
		scrollTrigger: {
			trigger: ".team-grid",
			start: "top 85%",
		},
		opacity: 0,
		y: 35,
		duration: 0.8,
		stagger: 0.15,
		ease: "power2.out"
	});
</script>
