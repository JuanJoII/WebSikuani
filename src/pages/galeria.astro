---
import Layout from '../layouts/Layout.astro';
import SectionHeader from '../components/SectionHeader.astro';

const images = [
	{ src: "https://images.unsplash.com/photo-1487525219605-eadb39ae229c?fm=jpg&q=60&w=3000&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxzZWFyY2h8Mnx8Ym9zcXVlJTIwcHJvZnVuZG98ZW58MHx8MHx8fDA%3D", title: "Bosque Profundo" },
	{ src: "https://cdn.cizucu.com/images/photos/xcekTspli1jAjwfH8M2S.jpg?auto=format%2Ccompress&fit=max&w=1536&q=90", title: "Luz Filtrada" },
	{ src: "https://img.freepik.com/foto-gratis/colinas-boscosas-rodeadas-niebla-cielo-nublado_181624-5455.jpg?semt=ais_hybrid&w=740&q=80", title: "Niebla Matinal" },
	{ src: "https://images.unsplash.com/photo-1501854140801-50d01698950b?auto=format&fit=crop&q=80&w=800", title: "Cumbres Verdes" },
	{ src: "https://w0.peakpx.com/wallpaper/251/755/HD-wallpaper-hidden-trails-forest-nature-road-trail.jpg", title: "Sendero Oculto" },
	{ src: "https://www.adobe.com/la/creativecloud/photography/discover/media_155373f24dc83487b560dbd9c0ff229084addc2c3.png?width=750&format=png&optimize=medium", title: "Reflejo de Agua" },
];
---

<Layout title="Galería - Sikuani">

	<main class="transition-colors duration-700 bg-sikuani-bg min-h-screen">
		<section class="py-24">
			<div class="container mx-auto px-4">
				<SectionHeader 
					title="Galería Visual" 
					subtitle="Inspiración Natural" 
					centered={true} 
				/>
				
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mt-16">
					{images.map(img => (
						<div class="group cursor-pointer overflow-hidden rounded-sikuani-card border border-sikuani-primary/10 bg-sikuani-surface shadow-lg">
							<div class="aspect-square overflow-hidden">
								<img 
									src={img.src} 
									alt={img.title} 
									class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700 ease-out"
								/>
							</div>
							<div class="p-6">
								<h3 class="text-xl font-serif text-sikuani-primary">{img.title}</h3>
								<p class="text-sm font-sans text-sikuani-on-surface/60 uppercase tracking-widest mt-2">Sikuani Essence</p>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>
	</main>

</Layout>
