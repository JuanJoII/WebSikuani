---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import Button from '../components/Button.astro';
---

<Layout title="Contacto - Sikuani Ecohotel">
	<main class="bg-canvas text-body min-h-screen overflow-x-hidden">
		<!-- Hero Section Estandarizado -->
		<PageHero 
			title="Ponte en contacto con nuestro refugio."
			description="Si deseas planificar retiros de bienestar, coordinar traslados o tienes preguntas sobre tu estadía, estamos listos para guiar tu camino."
		/>
		
		<!-- Cuerpo de Contacto -->
		<section class="py-24 max-w-[1200px] mx-auto px-6">
			<div class="flex flex-col lg:flex-row gap-16 items-start contact-container">
				
				<!-- Columna Izquierda: Información de Contacto -->
				<div class="w-full lg:w-1/2 space-y-8 contact-info">
					<h3 class="text-2xl font-serif font-normal text-ink mb-6 border-b border-hairline pb-4 select-none">
						Nuestros Canales
					</h3>
					
					<div class="space-y-8">
						<!-- Ubicación -->
						<div class="flex items-start gap-6 group select-none contact-item">
							<div class="h-12 w-12 rounded-sm bg-primary/10 text-primary flex items-center justify-center shrink-0 group-hover:scale-105 transition-transform duration-300">
								<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
									<path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
									<path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
								</svg>
							</div>
							<div>
								<h4 class="text-base font-serif font-bold text-ink">Dirección del Refugio</h4>
								<p class="text-sm text-muted font-sans mt-1">Cajicá, Cundinamarca, Colombia</p>
							</div>
						</div>
						
						<!-- Canales Digitales -->
						<div class="flex items-start gap-6 group select-none contact-item">
							<div class="h-12 w-12 rounded-sm bg-primary/10 text-primary flex items-center justify-center shrink-0 group-hover:scale-105 transition-transform duration-300">
								<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
									<path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
								</svg>
							</div>
							<div>
								<h4 class="text-base font-serif font-bold text-ink">Canales de Atención</h4>
								<p class="text-sm text-muted font-sans mt-1">hola@sikuani-resort.eco</p>
								<p class="text-sm text-muted font-sans mt-1">+57 (300) 456 7890</p>
							</div>
						</div>

						<!-- Recepción -->
						<div class="flex items-start gap-6 group select-none contact-item">
							<div class="h-12 w-12 rounded-sm bg-primary/10 text-primary flex items-center justify-center shrink-0 group-hover:scale-105 transition-transform duration-300">
								<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
									<path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
								</svg>
							</div>
							<div>
								<h4 class="text-base font-serif font-bold text-ink">Horarios de Recepción</h4>
								<p class="text-sm text-muted font-sans mt-1">Huéspedes: Recepción activa 24/7</p>
								<p class="text-sm text-muted font-sans mt-1">Administrativo: Lun-Vie 08:00 - 18:00</p>
							</div>
						</div>
					</div>
				</div>

				<!-- Columna Derecha: Formulario de Contacto -->
				<div class="w-full lg:w-1/2 contact-form">
					<form class="bg-canvas dark:bg-dark-surface p-8 md:p-10 rounded-md border border-hairline dark:border-dark-hairline shadow-hover space-y-6 select-none">
						<h3 class="text-2xl font-serif font-normal text-ink mb-6 border-b border-hairline pb-4 select-none">
							Envíanos un Mensaje
						</h3>
						
						<div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
							<div class="space-y-2">
								<label class="text-[10px] font-bold uppercase tracking-widest text-primary">Nombre</label>
								<input 
									type="text" 
									required
									class="w-full bg-surface-soft dark:bg-dark-surface-soft border border-hairline dark:border-dark-hairline py-3 px-4 rounded-sm text-ink dark:text-dark-ink font-sans outline-none focus:border-2 focus:border-primary transition-all text-sm" 
									placeholder="Tu nombre completo" 
								/>
							</div>
							<div class="space-y-2">
								<label class="text-[10px] font-bold uppercase tracking-widest text-primary">Correo</label>
								<input 
									type="email" 
									required
									class="w-full bg-surface-soft dark:bg-dark-surface-soft border border-hairline dark:border-dark-hairline py-3 px-4 rounded-sm text-ink dark:text-dark-ink font-sans outline-none focus:border-2 focus:border-primary transition-all text-sm" 
									placeholder="tu@correo.com" 
								/>
							</div>
						</div>

						<div class="space-y-2">
							<label class="text-[10px] font-bold uppercase tracking-widest text-primary">Asunto</label>
							<input 
								type="text" 
								required
								class="w-full bg-surface-soft dark:bg-dark-surface-soft border border-hairline dark:border-dark-hairline py-3 px-4 rounded-sm text-ink dark:text-dark-ink font-sans outline-none focus:border-2 focus:border-primary transition-all text-sm" 
								placeholder="Motivo de tu mensaje" 
							/>
						</div>
						
						<div class="space-y-2">
							<label class="text-[10px] font-bold uppercase tracking-widest text-primary">Mensaje</label>
							<textarea 
								rows="4" 
								required
								class="w-full bg-surface-soft dark:bg-dark-surface-soft border border-hairline dark:border-dark-hairline py-3 px-4 rounded-sm text-ink dark:text-dark-ink font-sans outline-none focus:border-2 focus:border-primary transition-all text-sm resize-none" 
								placeholder="¿Cómo podemos asistirte en tu viaje?"
							></textarea>
						</div>
						
						<Button variant="primary" class="w-full py-6 text-xs uppercase tracking-wider font-bold">
							Enviar Mensaje
						</Button>
					</form>
				</div>

			</div>
		</section>
	</main>
</Layout>

<script>
	import { gsap } from 'gsap';
	
	// Animaciones Hero Estandarizadas
	gsap.from(".hero-tag", { opacity: 0, y: -20, duration: 0.8, ease: "power2.out" });
	gsap.from(".hero-title", { opacity: 0, y: 30, duration: 1.2, delay: 0.2, ease: "power3.out" });
	gsap.from(".hero-desc", { opacity: 0, y: 20, duration: 1, delay: 0.4, ease: "power2.out" });

	// Animaciones de entrada coordinadas
	gsap.from(".contact-info", { opacity: 0, x: -40, duration: 1, delay: 0.4, ease: "power2.out" });
	gsap.from(".contact-form", { opacity: 0, x: 40, duration: 1, delay: 0.4, ease: "power2.out" });
	
	// Animación con stagger sobre los ítems de contacto a la izquierda
	gsap.from(".contact-item", {
		opacity: 0,
		y: 20,
		duration: 0.6,
		stagger: 0.15,
		delay: 0.8,
		ease: "power2.out"
	});
</script>
