---
import Button from './Button.astro';
import ThemeToggle from './ThemeToggle.astro';

const base = import.meta.env.BASE_URL;

const navLinks = [
	{ text: 'Inicio', href: `${base}` },
	{ text: 'Sobre Nosotros', href: `${base}sobre-nosotros/` },
	{ text: 'Galería', href: `${base}galeria/` },
	{ text: 'Contacto', href: `${base}contacto/` },
	{ text: 'Reservas', href: `${base}reservas/` },
];
---

<nav 
	id="main-nav" 
	class="fixed top-0 left-0 w-full z-50 bg-canvas/80 backdrop-blur-md border-b border-hairline py-1 transition-all duration-500 select-none shadow-none"
>
	<div class="max-w-[1200px] mx-auto px-6">
		<div 
			id="nav-inner" 
			class="flex justify-between items-center h-20 transition-all duration-500"
		>
			<!-- Logo a la izquierda con oscilación y resplandor en hover -->
			<div class="shrink-0">
				<a 
					href={base} 
					class="flex items-center gap-3 text-2xl font-serif text-primary tracking-tight transition-all duration-300 group select-none"
				>
					<img 
						src={`${base}lgo.png`} 
						alt="Sikuani Logo" 
						class="h-20 w-auto group-hover:rotate-6 group-hover:scale-105 transition-transform duration-500" 
					/>
					<span class="font-bold relative py-1">
						<span class="bg-gradient-to-r from-primary to-accent bg-clip-text text-transparent">Sikuani</span>
						<span class="absolute bottom-0 left-0 w-full h-[2.5px] bg-accent scale-x-0 group-hover:scale-x-100 transition-transform origin-left duration-500"></span>
					</span>
				</a>
			</div>
			
			<!-- Enlaces informativos centrados con indicador activo deslizante -->
			<div class="hidden md:block">
				<div class="flex items-center space-x-8">
					{navLinks.map(link => (
						<a 
							href={link.href} 
							class="relative py-2 text-ink hover:text-primary font-sans font-semibold text-sm transition-colors duration-300 group"
						>
							<span>{link.text}</span>
							<!-- Línea de acento deslizante desde el centro -->
							<span class="absolute bottom-0 left-0 w-full h-[2.5px] bg-primary scale-x-0 group-hover:scale-x-100 transition-transform origin-center duration-300"></span>
						</a>
					))}
				</div>
			</div>
			
			<!-- Preferencias de idioma, conmutador y botón a la derecha -->
			<div class="flex items-center gap-4 sm:gap-6">
				<!-- Selector de idioma con micro-punto indicador en hover -->
				<div class="hidden xs:flex items-center gap-1.5 group/lang cursor-pointer select-none py-2">
					<span class="h-1.5 w-1.5 rounded-full bg-primary scale-0 group-hover/lang:scale-100 transition-transform duration-300"></span>
					<span class="text-muted font-sans font-bold text-xs tracking-wider group-hover/lang:text-primary transition-colors duration-300">
						ES / EN
					</span>
				</div>
				<!-- Conmutador -->
				<ThemeToggle />
				<!-- Botón Contacto con micro-transición -->
				<div class="hidden sm:block">
					<Button href={`${base}contacto/`} variant="secondary" class="h-10 px-4 text-xs tracking-wider uppercase font-bold hover:scale-102 transition-transform shadow-hover">
						Contacto
					</Button>
				</div>
				<!-- Botón Hamburguesa Móvil (Absoluto, 100% robusto y centrado) -->
				<button 
					id="menu-toggle" 
					class="md:hidden relative flex items-center justify-center w-10 h-10 z-50 cursor-pointer outline-none group bg-surface-soft/80 dark:bg-dark-surface-soft/40 border border-hairline/60 dark:border-dark-hairline/60 rounded-full transition-all duration-300"
					aria-label="Abrir menú"
				>
					<div class="relative w-5 h-4 flex flex-col justify-between items-center">
						<span class="w-5 h-[2px] bg-ink dark:bg-dark-ink rounded-full transition-all duration-300 origin-center bar-1"></span>
						<span class="w-5 h-[2px] bg-ink dark:bg-dark-ink rounded-full transition-all duration-300 origin-center bar-2"></span>
						<span class="w-5 h-[2px] bg-ink dark:bg-dark-ink rounded-full transition-all duration-300 origin-center bar-3"></span>
					</div>
				</button>
			</div>
		</div>
	</div>

	<!-- Backdrop Oscurecido (Fondo translúcido con difuminado glassmorphism) -->
	<div 
		id="mobile-menu-backdrop" 
		class="fixed inset-0 z-30 bg-dark-canvas/40 backdrop-blur-md md:hidden hidden opacity-0 transition-all duration-300 cursor-pointer"
	></div>

	<!-- Sidebar de Navegación Móvil (Desplegable Lateral Derecho) -->
	<div 
		id="mobile-menu" 
		class="fixed top-0 right-0 w-[280px] sm:w-[320px] h-screen h-[100dvh] z-40 bg-canvas/98 dark:bg-dark-canvas/98 backdrop-blur-lg md:hidden flex flex-col p-8 pt-24 shadow-2xl justify-start items-start space-y-6 select-none transition-all duration-300 transform translate-x-full opacity-0 pointer-events-none border-l border-hairline dark:border-dark-hairline"
	>
		<h4 class="text-[10px] font-bold uppercase tracking-widest text-primary mb-2">Navegación</h4>
		{navLinks.map((link, i) => (
			<a 
				href={link.href} 
				class="mobile-nav-link text-lg font-serif text-ink dark:text-dark-ink hover:text-primary dark:hover:text-dark-primary font-bold transition-all duration-300 transform translate-x-8 opacity-0 w-full border-b border-hairline/60 dark:border-dark-hairline/60 pb-3"
				style={`transition-delay: ${i * 50}ms`}
			>
				{link.text}
			</a>
		))}
		
		<!-- Botón de Contacto en Menú Móvil -->
		<div class="pt-4 w-full mobile-nav-link transform translate-x-8 opacity-0 transition-all duration-300" style={`transition-delay: ${navLinks.length * 50}ms`}>
			<Button href={`${base}contacto/`} variant="primary" class="w-full py-4 text-xs uppercase tracking-wider font-bold text-center">
				Contacto
			</Button>
		</div>
	</div>
</nav>
<!-- Espaciador fijo para compensar la barra de navegación fija de 80px -->
<div class="h-20"></div>

<script>
	// Script del cliente para manejar el encogimiento y estilo al hacer scroll
	const mainNav = document.getElementById("main-nav");
	const navInner = document.getElementById("nav-inner");

	const handleScroll = () => {
		if (window.scrollY > 20) {
			// Cambios al hacer scroll
			mainNav?.classList.add("bg-canvas/95", "shadow-sm", "py-0");
			mainNav?.classList.remove("bg-canvas/80", "shadow-none", "py-1");
			navInner?.classList.add("h-16");
			navInner?.classList.remove("h-20");
		} else {
			// Retorno al estado original
			mainNav?.classList.remove("bg-canvas/95", "shadow-sm", "py-0");
			mainNav?.classList.add("bg-canvas/80", "shadow-none", "py-1");
			navInner?.classList.remove("h-16");
			navInner?.classList.add("h-20");
		}
	};

	// Registrar listener de scroll y ejecutar inicialmente
	window.addEventListener("scroll", handleScroll);
	handleScroll();

	// Lógica de Menú Móvil (Sidebar Desplegable Lateral)
	const menuToggle = document.getElementById("menu-toggle");
	const mobileMenu = document.getElementById("mobile-menu");
	const menuBackdrop = document.getElementById("mobile-menu-backdrop");
	const navLinksElements = document.querySelectorAll(".mobile-nav-link");

	let isMenuOpen = false;

	const toggleMenu = (show) => {
		isMenuOpen = show === undefined ? !isMenuOpen : show;
		
		const bar1 = menuToggle?.querySelector(".bar-1");
		const bar2 = menuToggle?.querySelector(".bar-2");
		const bar3 = menuToggle?.querySelector(".bar-3");

		if (isMenuOpen) {
			menuToggle?.classList.add("menu-open");
			bar1?.classList.add("rotate-45", "translate-y-[7px]");
			bar2?.classList.add("opacity-0", "scale-0");
			bar3?.classList.add("-rotate-45", "-translate-y-[7px]");
			
			// Mostrar Backdrop
			if (menuBackdrop) {
				menuBackdrop.classList.remove("hidden");
				menuBackdrop.offsetHeight; // Forzar reflujo
				menuBackdrop.classList.remove("opacity-0");
				menuBackdrop.classList.add("opacity-100");
			}

			// Desplegar Sidebar
			mobileMenu?.classList.remove("pointer-events-none", "translate-x-full", "opacity-0");
			mobileMenu?.classList.add("translate-x-0", "opacity-100", "pointer-events-auto");
			document.body.classList.add("overflow-hidden");
			
			setTimeout(() => {
				navLinksElements.forEach(el => {
					el.classList.remove("translate-x-8", "opacity-0");
					el.classList.add("translate-x-0", "opacity-100");
				});
			}, 50);
		} else {
			menuToggle?.classList.remove("menu-open");
			bar1?.classList.remove("rotate-45", "translate-y-[7px]");
			bar2?.classList.remove("opacity-0", "scale-0");
			bar3?.classList.remove("-rotate-45", "-translate-y-[7px]");
			
			// Ocultar Backdrop con fade
			if (menuBackdrop) {
				menuBackdrop.classList.remove("opacity-100");
				menuBackdrop.classList.add("opacity-0");
				setTimeout(() => {
					if (menuBackdrop.classList.contains("opacity-0")) {
						menuBackdrop.classList.add("hidden");
					}
				}, 300);
			}

			// Replegar Sidebar
			mobileMenu?.classList.remove("translate-x-0", "opacity-100", "pointer-events-auto");
			mobileMenu?.classList.add("translate-x-full", "opacity-0", "pointer-events-none");
			document.body.classList.remove("overflow-hidden");
			
			navLinksElements.forEach(el => {
				el.classList.add("translate-x-8", "opacity-0");
				el.classList.remove("translate-y-0", "opacity-100");
			});
		}
	};

	menuToggle?.addEventListener("click", () => toggleMenu());
	menuBackdrop?.addEventListener("click", () => toggleMenu(false));

	navLinksElements.forEach(link => {
		link.addEventListener("click", () => {
			toggleMenu(false);
		});
	});
</script>
