---
import Button from './Button.astro';
import ThemeToggle from './ThemeToggle.astro';

const base = import.meta.env.BASE_URL;

const navLinks = [
	{ text: 'Inicio', href: `${base}` },
	{ text: 'Sobre Nosotros', href: `${base}sobre-nosotros/` },
	{ text: 'Galería', href: `${base}galeria/` },
	{ text: 'Contacto', href: `${base}contacto/` },
	{ text: 'Reservas', href: `${base}reservas/` },
];
---

<nav 
	id="main-nav" 
	class="fixed top-0 left-0 w-full z-50 bg-canvas/80 backdrop-blur-md border-b border-hairline py-1 transition-all duration-500 select-none shadow-none"
>
	<div class="max-w-[1200px] mx-auto px-6">
		<div 
			id="nav-inner" 
			class="flex justify-between items-center h-20 transition-all duration-500"
		>
			<!-- Logo a la izquierda con oscilación y resplandor en hover -->
			<div class="shrink-0">
				<a 
					href={base} 
					class="flex items-center gap-3 text-2xl font-serif text-primary tracking-tight transition-all duration-300 group select-none"
				>
					<img 
						src={`${base}LogoColor_3.png`} 
						alt="Sikuani Logo" 
						class="h-9 w-auto group-hover:rotate-6 group-hover:scale-105 transition-transform duration-500" 
					/>
					<span class="font-bold relative py-1">
						Sikuani
						<span class="absolute bottom-0 left-0 w-full h-[2.5px] bg-accent scale-x-0 group-hover:scale-x-100 transition-transform origin-left duration-500"></span>
					</span>
				</a>
			</div>
			
			<!-- Enlaces informativos centrados con indicador activo deslizante -->
			<div class="hidden md:block">
				<div class="flex items-center space-x-8">
					{navLinks.map(link => (
						<a 
							href={link.href} 
							class="relative py-2 text-ink hover:text-primary font-sans font-semibold text-sm transition-colors duration-300 group"
						>
							<span>{link.text}</span>
							<!-- Línea de acento deslizante desde el centro -->
							<span class="absolute bottom-0 left-0 w-full h-[2.5px] bg-primary scale-x-0 group-hover:scale-x-100 transition-transform origin-center duration-300"></span>
						</a>
					))}
				</div>
			</div>
			
			<!-- Preferencias de idioma, conmutador y botón a la derecha -->
			<div class="flex items-center gap-6">
				<!-- Selector de idioma con micro-punto indicador en hover -->
				<div class="flex items-center gap-1.5 group/lang cursor-pointer select-none py-2">
					<span class="h-1.5 w-1.5 rounded-full bg-primary scale-0 group-hover/lang:scale-100 transition-transform duration-300"></span>
					<span class="text-muted font-sans font-bold text-xs tracking-wider group-hover/lang:text-primary transition-colors duration-300">
						ES / EN
					</span>
				</div>
				<!-- Conmutador -->
				<ThemeToggle />
				<!-- Botón Contacto con micro-transición -->
				<div class="hidden sm:block">
					<Button href={`${base}contacto/`} variant="secondary" class="h-10 px-4 text-xs tracking-wider uppercase font-bold hover:scale-102 transition-transform shadow-hover">
						Contacto
					</Button>
				</div>
			</div>
		</div>
	</div>
</nav>
<!-- Espaciador fijo para compensar la barra de navegación fija de 80px -->
<div class="h-20"></div>

<script>
	// Script del cliente para manejar el encogimiento y estilo al hacer scroll
	const mainNav = document.getElementById("main-nav");
	const navInner = document.getElementById("nav-inner");

	const handleScroll = () => {
		if (window.scrollY > 20) {
			// Cambios al hacer scroll
			mainNav?.classList.add("bg-canvas/95", "shadow-sm", "py-0");
			mainNav?.classList.remove("bg-canvas/80", "shadow-none", "py-1");
			navInner?.classList.add("h-16");
			navInner?.classList.remove("h-20");
		} else {
			// Retorno al estado original
			mainNav?.classList.remove("bg-canvas/95", "shadow-sm", "py-0");
			mainNav?.classList.add("bg-canvas/80", "shadow-none", "py-1");
			navInner?.classList.remove("h-16");
			navInner?.classList.add("h-20");
		}
	};

	// Registrar listener de scroll y ejecutar inicialmente
	window.addEventListener("scroll", handleScroll);
	handleScroll();
</script>
