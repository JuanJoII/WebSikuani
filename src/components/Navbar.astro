---
import Button from './Button.astro';
import ThemeToggle from './ThemeToggle.astro';

const navLinks = [
	{ text: 'Inicio', href: '/' },
	{ text: 'Sobre Nosotros', href: '/sobre-nosotros' },
	{ text: 'Galería', href: '/galeria' },
	{ text: 'Contacto', href: '/contacto' },
];
---

<nav class="fixed top-0 left-0 w-full z-50 bg-sikuani-bg/80 backdrop-blur-md border-b border-sikuani-primary/10 transition-all duration-700">
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
		<div class="flex justify-between items-center h-20">
			<div class="flex-shrink-0">
				<a href="/" class="text-3xl font-serif text-sikuani-primary tracking-tight transition-all duration-700">
					Sikuani
				</a>
			</div>
			
			<div class="hidden md:block">
				<div class="ml-10 flex items-baseline space-x-8">
					{navLinks.map(link => (
						<a 
							href={link.href} 
							class="text-sikuani-on-surface hover:text-sikuani-primary font-sans font-medium transition-colors inline-block"
						>
							{link.text}
						</a>
					))}
				</div>
			</div>
			
			<div class="flex items-center gap-4">
				<ThemeToggle />
				<div class="hidden md:block">
					<Button href="/contacto" variant="primary">Contacto</Button>
				</div>
			</div>
		</div>
	</div>
</nav>
<div class="h-20"></div>
