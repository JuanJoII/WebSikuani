---
const base = import.meta.env.BASE_URL;

const footerLinks = [
	{
		title: 'Refugio',
		links: [
			{ text: 'Inicio', href: `${base}` },
			{ text: 'Sobre Nosotros', href: `${base}sobre-nosotros/` },
			{ text: 'Reservas', href: `${base}reservas/` }
		]
	},
	{
		title: 'Explorar',
		links: [
			{ text: 'Galería', href: `${base}galeria/` },
			{ text: 'Contacto', href: `${base}contacto/` }
		]
	}
];
---

<footer class="bg-primary text-white py-16 px-6 border-t border-hairline/10 transition-colors duration-500 select-none">
	<div class="max-w-[1200px] mx-auto grid grid-cols-1 md:grid-cols-4 gap-12">
		<!-- Marca descriptiva -->
		<div class="col-span-1 md:col-span-2 space-y-4">
			<a href={base} class="text-3xl font-serif font-bold text-white tracking-tight">
				Sikuani
			</a>
			<p class="max-w-md font-sans text-sm leading-relaxed text-white/80">Fomentando el descanso consciente y la inmersión natural regenerativa a través del respeto y el diseño biomimético. Un santuario para restaurar tu equilibrio biológico.</p>
		</div>

		<!-- Enlaces dinámicos -->
		{footerLinks.map(section => (
			<div>
				<h4 class="font-sans font-bold text-xs uppercase tracking-widest text-accent mb-6">
					{section.title}
				</h4>
				<ul class="space-y-3">
					{section.links.map(link => (
						<li>
							<a href={link.href} class="font-sans text-sm text-white/70 hover:text-white transition-colors duration-300">
								{link.text}
							</a>
						</li>
					))}
				</ul>
			</div>
		))}
	</div>

	<!-- Copyright y Legales -->
	<div class="max-w-[1200px] mx-auto mt-16 pt-8 border-t border-white/10 flex flex-col sm:flex-row justify-between items-center gap-4 text-xs text-white/50">
		<p class="text-white/50">© {new Date().getFullYear()} Sikuani Ecohotel. Todos los derechos reservados.</p>
		<div class="flex gap-6">
			<a href="#" class="hover:underline transition-all">Políticas de Privacidad</a>
			<a href="#" class="hover:underline transition-all">Términos del Refugio</a>
		</div>
	</div>
</footer>
