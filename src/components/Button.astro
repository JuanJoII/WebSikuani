---
interface Props {
	href?: string;
	variant?: 'primary' | 'conversion' | 'secondary';
	class?: string;
	[key: string]: any;
}

const { href, variant = 'primary', class: className, ...rest } = Astro.props;

const baseStyles = "h-12 px-6 rounded-sm transition-all duration-300 font-sans flex items-center justify-center text-center inline-flex cursor-pointer border border-transparent select-none";

const variants = {
	primary: "bg-primary text-white hover:bg-primary-light font-bold dark:bg-primary dark:text-canvas dark:hover:bg-primary-light",
	conversion: "bg-accent text-ink hover:opacity-90 font-semibold dark:bg-accent dark:text-canvas dark:hover:opacity-90",
	secondary: "bg-transparent border-primary text-primary hover:bg-primary/5 font-semibold dark:border-primary dark:text-primary dark:hover:bg-primary/5"
};

const Tag = href ? 'a' : 'button';
---

<Tag {href} class:list={[baseStyles, variants[variant], className]} {...rest}>
	<slot />
</Tag>
