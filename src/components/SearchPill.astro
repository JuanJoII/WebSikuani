---
const base = import.meta.env.BASE_URL;
---

<div class="w-full max-w-[800px] mx-auto bg-canvas dark:bg-dark-surface border border-hairline dark:border-dark-hairline rounded-full p-2 flex flex-col md:flex-row items-center gap-2 md:gap-0 transition-all duration-300 shadow-hover select-none cursor-pointer">
  <!-- Segmento 1: Destino -->
  <div class="flex-1 w-full px-6 py-2 text-left md:border-r border-hairline dark:border-dark-hairline group">
    <span class="block text-[10px] font-bold text-primary dark:text-primary-light uppercase tracking-widest mb-0.5">Destino / Refugio</span>
    <span class="block text-sm font-sans font-medium text-ink dark:text-dark-ink group-hover:text-primary transition-colors">Bosque de Niebla, Cajicá</span>
  </div>

  <!-- Segmento 2: Fechas -->
  <div class="flex-1 w-full px-6 py-2 text-left md:border-r border-hairline dark:border-dark-hairline group">
    <span class="block text-[10px] font-bold text-primary dark:text-primary-light uppercase tracking-widest mb-0.5">Fechas / Estadía</span>
    <span class="block text-sm font-sans font-medium text-ink dark:text-dark-ink group-hover:text-primary transition-colors">14 Oct. - 18 Oct. 2024</span>
  </div>

  <!-- Segmento 3: Huéspedes -->
  <div class="flex-1 w-full px-6 py-2 text-left md:mr-2 group">
    <span class="block text-[10px] font-bold text-primary dark:text-primary-light uppercase tracking-widest mb-0.5">Huéspedes</span>
    <span class="block text-sm font-sans font-medium text-ink dark:text-dark-ink group-hover:text-primary transition-colors">2 Adultos</span>
  </div>

  <!-- Botón de Búsqueda -->
  <div class="shrink-0 w-full md:w-auto flex justify-end md:justify-center px-4 md:px-0">
    <a href={`${base}reservas/`} class="h-12 w-full md:w-12 rounded-full bg-primary text-white flex items-center justify-center hover:scale-105 transition-transform duration-300 shadow-lg">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
      </svg>
      <span class="block md:hidden font-sans font-bold text-sm ml-2">Buscar Refugio</span>
    </a>
  </div>
</div>
