---
interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<section class="py-24 relative overflow-hidden border-b border-hairline transition-colors duration-500">
  <!-- Acentos Visuales de Fondo -->
  <div class="absolute inset-0 opacity-10 pointer-events-none select-none">
    <div class="absolute top-[-10%] right-[-5%] w-96 h-96 bg-primary rounded-full blur-[120px]"></div>
    <div class="absolute bottom-[-10%] left-[-5%] w-96 h-96 bg-accent rounded-full blur-[100px]"></div>
  </div>

  <div class="max-w-[1200px] mx-auto px-6 relative z-10 text-center">
    
    <h1 class="text-5xl md:text-7xl font-serif text-ink mb-8 leading-tight tracking-tight max-w-4xl mx-auto hero-title">
      {title}
    </h1>
    
    <p class="text-lg md:text-xl text-body font-sans leading-relaxed max-w-3xl mx-auto hero-desc">
      {description}
    </p>
  </div>
</section>
