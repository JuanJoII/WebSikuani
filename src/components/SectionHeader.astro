---
interface Props {
	title: string;
	subtitle?: string;
	centered?: boolean;
}

const { title, subtitle, centered = false } = Astro.props;
---

<div class:list={["mb-12 select-none", centered ? "text-center flex flex-col items-center" : "text-left"]}>
	{subtitle && (
		<span class="text-primary font-sans font-bold uppercase tracking-widest text-[11px] mb-3 block">
			{subtitle}
		</span>
	)}
	<h2 class="text-3xl md:text-4xl lg:text-5xl font-serif font-normal text-ink mb-5 leading-tight tracking-tight max-w-3xl">
		{title}
	</h2>
	<div class:list={[
		"h-[3px] w-16 rounded-full bg-accent transition-colors duration-500",
		centered ? "mx-auto" : ""
	]}></div>
</div>
