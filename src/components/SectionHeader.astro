---
interface Props {
	title: string;
	subtitle?: string;
	centered?: boolean;
	dark?: boolean;
}

const { title, subtitle, centered = false, dark = false } = Astro.props;
---

<div class:list={["mb-16 transition-colors duration-500", centered ? "text-center flex flex-col items-center" : "text-left"]}>
	{subtitle && (
		<span class="text-sikuani-primary font-sans font-bold uppercase tracking-widest text-sm mb-4 block">
			{subtitle}
		</span>
	)}
	<h2 class:list={[
		"text-4xl md:text-5xl lg:text-6xl font-serif mb-6 leading-tight",
		dark ? "text-white" : "text-sikuani-on-surface"
	]}>
		{title}
	</h2>
	<div class:list={[
		"h-1 w-20 rounded-full bg-sikuani-accent dark:bg-sikuani-primary",
		centered ? "mx-auto" : ""
	]}></div>
</div>
