---
import fs from 'node:fs';
import path from 'node:path';

interface Props {
  amenities?: string[];
  compact?: boolean;
}

const { 
  amenities = ['recepcion', 'habitaciones', 'duchas', 'parrilla', 'zonas_verdes', 'spa'], 
  compact = false 
} = Astro.props;

// Configuración de los archivos SVG propios de Sikuani en ElementosGraficos
const iconFiles = {
  recepcion: { file: 'Recepcion.svg', label: 'Recepción' },
  habitaciones: { file: 'Habitaciones.svg', label: 'Habitaciones' },
  duchas: { file: 'Duchas.svg', label: 'Duchas' },
  parrilla: { file: 'ZonaParrilla.svg', label: 'Zona Parrilla' },
  zonas_verdes: { file: 'ZoansVerdes.svg', label: 'Zonas Verdes' },
  spa: { file: 'Spa.svg', label: 'Spa' }
};

// Cargar y procesar los SVGs en el servidor durante el build
const iconMap: Record<string, { label: string; svg: string }> = {};

for (const [key, info] of Object.entries(iconFiles)) {
  try {
    const filePath = path.resolve(`./public/ElementosGraficos/${info.file}`);
    let svgContent = fs.readFileSync(filePath, 'utf-8');
    
    // Limpiar metadatos del SVG para renderizado inline impecable
    svgContent = svgContent
      .replace(/<\?xml.*?\?>/gi, '')
      .replace(/<!DOCTYPE.*?>/gi, '')
      .replace(/fill:rgb\(\d+,\s*\d+,\s*\d+\)/g, 'fill:currentColor') // Cambiar color verde estático a currentColor para heredar text-primary
      .trim();
      
    iconMap[key] = {
      label: info.label,
      svg: svgContent
    };
  } catch (error) {
    console.error(`Error cargando SVG propio de Sikuani para ${key}:`, error);
  }
}
---

<div class:list={[
  "grid gap-4", 
  compact 
    ? "flex flex-wrap gap-2 text-xs" 
    : "grid-cols-2 sm:grid-cols-3 md:grid-cols-6 text-sm"
]}>
  {amenities.map(key => {
    const item = iconMap[key];
    if (!item) return null;
    
    return compact ? (
      <div class="flex items-center gap-1.5 bg-surface-soft border border-hairline px-2.5 py-1 rounded-full text-muted transition-colors select-none">
        <span class="text-primary h-4 w-4 flex items-center justify-center amenity-compact-container" set:html={item.svg} />
        <span class="font-sans font-medium text-[11px]">{item.label}</span>
      </div>
    ) : (
      <div class="flex flex-col items-center justify-start p-4 h-36 rounded-md bg-canvas border border-hairline text-center transition-all duration-300 hover:border-primary/30 group shadow-hover select-none">
        <div class="h-10 w-10 rounded-full bg-primary/10 text-primary flex items-center justify-center mb-3 group-hover:scale-110 transition-transform duration-300 p-2 amenity-svg-container" set:html={item.svg} />
        <h4 class="font-sans font-bold text-ink text-xs uppercase tracking-wider">{item.label}</h4>
      </div>
    );
  })}
</div>

<style>
  /* Forzar dimensiones homogéneas y alineación óptica de los SVGs inyectados inline */
  .amenity-svg-container :global(svg) {
    height: 1.25rem !important; /* 20px (h-5) para alineación horizontal perfecta */
    width: auto !important;
    display: inline-block;
  }
  
  .amenity-compact-container :global(svg) {
    height: 1rem !important; /* 16px (h-4) en tarjetas y badges */
    width: auto !important;
    display: inline-block;
  }
</style>
